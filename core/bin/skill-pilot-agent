#!/bin/bash

# Skill Pilot Agent CLI Wrapper
# This script runs the Node.js agent implementation.

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
AGENT_ROOT="$SCRIPT_DIR/../engine/skill_pilot_agent"

# Prefer compiled output for production, fall back to ts-node for development.
if [ -f "$AGENT_ROOT/dist/index.js" ]; then
  node "$AGENT_ROOT/dist/index.js" "$@"
else
  npx ts-node "$AGENT_ROOT/src/index.ts" "$@"
fi
